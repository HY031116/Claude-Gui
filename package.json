{
  "name": "claude-code-gui",
  "private": true,
  "version": "1.9.2",
  "description": "Claude Code GUI - Electron desktop app for Claude Code CLI",
  "author": "Claude Code GUI Contributors",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --port 5185 --strictPort",
    "build": "tsc -b && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').copyFileSync('electron/assets/package.json', 'dist-electron/package.json')\"",
    "electron": "npm run build:electron && node scripts/start-electron.cjs",
    "electron:dev": "concurrently --kill-others \"vite --port 5185 --strictPort\" \"npm run build:electron && npx tsc -p electron/tsconfig.json --watch --preserveWatchOutput\" \"wait-on tcp:5185 && node scripts/dev-with-reload.cjs\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "ansi-to-html": "^0.7.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.claude.code-gui",
    "productName": "Claude Code GUI",
    "copyright": "Copyright 漏 2025 Claude Code GUI Contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Code GUI"
    },
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "nativeRebuilder": "legacy",
    "extraResources": [
      {
        "from": "node_modules/node-pty",
        "to": "node_modules/node-pty",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
