{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node .github/hooks/continuous-iteration.cjs",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node .github/hooks/continuous-iteration.cjs",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/continuous-iteration.cjs",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/continuous-iteration.cjs",
        "timeout": 10
      }
    ]
  }
}